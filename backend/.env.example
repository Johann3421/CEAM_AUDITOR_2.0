# =============================================================================
# CEAM AUDITOR 2.0 — Environment Variables
# Copy this file to .env and fill in the real values.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@db:5432/ceam_auditor

# --- Redis / Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- FastAPI ---
PROJECT_NAME=CEAM AUDITOR
